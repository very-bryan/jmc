<%= form_with model: [:admin, announcement], class: "space-y-5" do |f| %>
  <% if announcement.errors.any? %>
    <div class="flex items-start gap-2 rounded-md border border-red-200 bg-red-50 px-3 py-2">
      <i data-lucide="alert-circle" class="w-4 h-4 text-red-500 flex-shrink-0 mt-0.5"></i>
      <div><% announcement.errors.full_messages.each do |msg| %><p class="text-sm text-red-700"><%= msg %></p><% end %></div>
    </div>
  <% end %>

  <div>
    <label class="text-sm font-medium mb-1.5 block">제목</label>
    <%= f.text_field :title, required: true, class: "shadcn-input w-full" %>
  </div>

  <div>
    <label class="text-sm font-medium mb-1.5 block">내용</label>
    <%= f.text_area :content, required: true, rows: 6, class: "shadcn-input w-full h-auto resize-none" %>
  </div>

  <div class="grid grid-cols-1 md:grid-cols-3 gap-4">
    <div>
      <label class="text-sm font-medium mb-1.5 block">대상</label>
      <%= f.select :target_audience, [["전체", "all_users"], ["남성만", "male_only"], ["여성만", "female_only"]], {}, class: "shadcn-input w-full" %>
    </div>
    <div>
      <label class="text-sm font-medium mb-1.5 block">시작일</label>
      <%= f.datetime_local_field :starts_at, class: "shadcn-input w-full" %>
    </div>
    <div>
      <label class="text-sm font-medium mb-1.5 block">종료일</label>
      <%= f.datetime_local_field :ends_at, class: "shadcn-input w-full" %>
    </div>
  </div>

  <label class="flex items-center gap-2 text-sm">
    <%= f.check_box :active, class: "rounded border-input" %>
    활성화
  </label>

  <div class="flex gap-3">
    <%= f.submit (announcement.persisted? ? "수정" : "작성"), class: "shadcn-btn shadcn-btn-primary cursor-pointer" %>
    <%= link_to "취소", admin_announcements_path, class: "shadcn-btn shadcn-btn-outline" %>
  </div>
<% end %>
