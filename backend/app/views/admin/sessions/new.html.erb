<div class="w-full max-w-sm">
  <div class="shadcn-card p-6 shadow-sm">
    <div class="text-center mb-6">
      <div class="w-10 h-10 rounded-lg bg-primary mx-auto mb-3 flex items-center justify-center">
        <span class="text-primary-foreground text-sm font-bold">JM</span>
      </div>
      <h1 class="text-lg font-semibold tracking-tight">Admin Login</h1>
      <p class="text-sm text-muted-foreground mt-1">관리자 계정으로 로그인하세요</p>
    </div>

    <% if flash[:alert] %>
      <div class="flex items-center gap-2 rounded-md border border-red-200 bg-red-50 px-3 py-2 mb-4">
        <i data-lucide="alert-circle" class="w-4 h-4 text-red-500 flex-shrink-0"></i>
        <p class="text-sm text-red-700"><%= flash[:alert] %></p>
      </div>
    <% end %>
    <% if flash[:notice] %>
      <div class="flex items-center gap-2 rounded-md border border-emerald-200 bg-emerald-50 px-3 py-2 mb-4">
        <i data-lucide="check-circle-2" class="w-4 h-4 text-emerald-500 flex-shrink-0"></i>
        <p class="text-sm text-emerald-700"><%= flash[:notice] %></p>
      </div>
    <% end %>

    <%= form_tag admin_login_path, method: :post, class: "space-y-4" do %>
      <div>
        <label class="text-sm font-medium leading-none mb-1.5 block">이메일</label>
        <input type="email" name="email" required autofocus placeholder="admin@example.com" class="shadcn-input">
      </div>
      <div>
        <label class="text-sm font-medium leading-none mb-1.5 block">비밀번호</label>
        <input type="password" name="password" required placeholder="비밀번호" class="shadcn-input">
      </div>
      <button type="submit" class="shadcn-btn shadcn-btn-primary w-full">로그인</button>
    <% end %>
  </div>
</div>
<script>lucide.createIcons();</script>
