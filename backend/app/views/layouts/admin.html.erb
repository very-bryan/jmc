<!DOCTYPE html>
<html lang="ko" class="h-full">
<head>
  <meta charset="UTF-8">
  <meta name="viewport" content="width=device-width, initial-scale=1.0">
  <meta name="csrf-token" content="<%= form_authenticity_token %>">
  <title>JMC Admin</title>
  <script src="https://cdn.tailwindcss.com"></script>
  <script src="https://unpkg.com/lucide@latest"></script>
  <script>
    tailwind.config = {
      theme: {
        extend: {
          colors: {
            background: '#ffffff',
            foreground: '#0a0a0a',
            card: '#ffffff',
            'card-foreground': '#0a0a0a',
            muted: '#f5f5f5',
            'muted-foreground': '#737373',
            border: '#e5e5e5',
            input: '#e5e5e5',
            primary: '#171717',
            'primary-foreground': '#fafafa',
            secondary: '#f5f5f5',
            'secondary-foreground': '#171717',
            accent: '#f5f5f5',
            'accent-foreground': '#171717',
            destructive: '#ef4444',
            'destructive-foreground': '#fafafa',
            ring: '#171717',
            sidebar: '#fafafa',
            'sidebar-border': '#e5e5e5',
            'sidebar-foreground': '#0a0a0a',
            'sidebar-muted': '#f5f5f5',
          },
          borderRadius: { lg: '0.5rem', md: 'calc(0.5rem - 2px)', sm: 'calc(0.5rem - 4px)' },
          fontSize: { '2xs': '0.625rem' },
        }
      }
    }
  </script>
  <style>
    * { border-color: #e5e5e5; }
    body { font-family: -apple-system, BlinkMacSystemFont, 'Segoe UI', Roboto, sans-serif; -webkit-font-smoothing: antialiased; }
    .shadcn-input { display: flex; height: 2.25rem; width: 100%; border-radius: 0.375rem; border: 1px solid #e5e5e5; background: transparent; padding: 0.5rem 0.75rem; font-size: 0.875rem; transition: all 0.15s; outline: none; }
    .shadcn-input:focus { border-color: #171717; box-shadow: 0 0 0 1px #171717; }
    .shadcn-btn { display: inline-flex; align-items: center; justify-content: center; border-radius: 0.375rem; font-size: 0.875rem; font-weight: 500; height: 2.25rem; padding: 0 1rem; transition: all 0.15s; cursor: pointer; border: none; }
    .shadcn-btn-primary { background: #171717; color: #fafafa; }
    .shadcn-btn-primary:hover { background: #171717e6; }
    .shadcn-btn-outline { background: transparent; border: 1px solid #e5e5e5; color: #0a0a0a; }
    .shadcn-btn-outline:hover { background: #f5f5f5; }
    .shadcn-btn-destructive { background: #ef4444; color: #fafafa; }
    .shadcn-btn-destructive:hover { background: #dc2626; }
    .shadcn-btn-ghost { background: transparent; color: #0a0a0a; }
    .shadcn-btn-ghost:hover { background: #f5f5f5; }
    .shadcn-card { border-radius: 0.5rem; border: 1px solid #e5e5e5; background: #fff; }
    .shadcn-badge { display: inline-flex; align-items: center; border-radius: 9999px; border: 1px solid transparent; padding: 0.125rem 0.625rem; font-size: 0.75rem; font-weight: 500; line-height: 1; }
    .shadcn-table { width: 100%; caption-side: bottom; font-size: 0.875rem; }
    .shadcn-table th { height: 2.5rem; padding: 0 1rem; text-align: left; font-weight: 500; color: #737373; }
    .shadcn-table td { padding: 0.75rem 1rem; vertical-align: middle; }
    .shadcn-table tbody tr { border-bottom: 1px solid #e5e5e5; transition: background 0.15s; }
    .shadcn-table tbody tr:hover { background: #fafafa; }
    .nav-link { display: flex; align-items: center; gap: 0.75rem; padding: 0.5rem 0.75rem; border-radius: 0.375rem; font-size: 0.875rem; font-weight: 500; color: #737373; transition: all 0.15s; }
    .nav-link:hover { background: #f5f5f5; color: #0a0a0a; }
    .nav-link.active { background: #f5f5f5; color: #0a0a0a; }
    .stat-card { padding: 1.25rem; }
    .stat-card .stat-value { font-size: 1.5rem; font-weight: 700; letter-spacing: -0.025em; color: #0a0a0a; }
    .stat-card .stat-label { font-size: 0.75rem; color: #737373; margin-top: 0.125rem; }
  </style>
</head>
<body class="h-full bg-background text-foreground">
  <% if defined?(current_admin) && current_admin %>
    <div class="flex h-full">
      <!-- Sidebar -->
      <aside class="w-60 border-r border-sidebar-border bg-sidebar flex flex-col flex-shrink-0">
        <div class="p-4 pb-3">
          <div class="flex items-center gap-2">
            <div class="w-7 h-7 rounded-md bg-primary flex items-center justify-center">
              <span class="text-primary-foreground text-xs font-bold">JM</span>
            </div>
            <div>
              <div class="text-sm font-semibold text-sidebar-foreground">JMC Admin</div>
            </div>
          </div>
        </div>

        <nav class="flex-1 overflow-y-auto px-3 py-2 space-y-0.5">
          <%= admin_nav_link "대시보드", admin_root_path, "layout-dashboard" %>
          <%= admin_nav_link "회원 관리", admin_users_path, "users" %>
          <%= admin_nav_link "신고 관리", admin_reports_path, "shield-alert" %>
          <%= admin_nav_link "콘텐츠 관리", admin_posts_path, "file-text" %>
          <%= admin_nav_link "관계 관리", admin_relationships_path, "heart-handshake" %>
          <%= admin_nav_link "통계", admin_statistics_path, "bar-chart-3" %>
          <%= admin_nav_link "공지사항", admin_announcements_path, "megaphone" %>
          <%= admin_nav_link "사전등록", admin_pre_registrations_path, "clipboard-list" %>
          <%= admin_nav_link "조직 도메인", admin_organization_domains_path, "building-2" %>

          <div class="mt-4 mb-1 px-3">
            <span class="text-2xs font-medium uppercase tracking-wider text-muted-foreground">외부 도구</span>
          </div>
          <a href="https://jmc-umami.verycloud.io" target="_blank" rel="noopener" class="nav-link">
            <i data-lucide="area-chart" class="w-4 h-4"></i>
            <span>데이터 분석</span>
            <i data-lucide="external-link" class="w-3 h-3 ml-auto text-muted-foreground"></i>
          </a>
        </nav>

        <div class="p-3 border-t border-sidebar-border">
          <div class="flex items-center gap-2 px-2">
            <div class="w-7 h-7 rounded-full bg-muted flex items-center justify-center">
              <i data-lucide="user" class="w-3.5 h-3.5 text-muted-foreground"></i>
            </div>
            <div class="flex-1 min-w-0">
              <div class="text-sm font-medium truncate"><%= current_admin.name %></div>
              <div class="text-2xs text-muted-foreground"><%= { "super_admin" => "Super Admin", "ops_admin" => "Ops Admin", "cs_admin" => "CS Admin", "data_admin" => "Data Admin" }[current_admin.role] %></div>
            </div>
          </div>
          <%= link_to admin_logout_path, class: "flex items-center gap-2 px-2 py-1.5 mt-2 text-xs text-muted-foreground hover:text-destructive transition rounded-md hover:bg-muted" do %>
            <i data-lucide="log-out" class="w-3.5 h-3.5"></i> 로그아웃
          <% end %>
        </div>
      </aside>

      <!-- Main Content -->
      <main class="flex-1 overflow-y-auto bg-background">
        <% if flash[:notice] %>
          <div class="mx-6 mt-4 flex items-center gap-2 rounded-md border border-green-200 bg-green-50 px-4 py-3">
            <i data-lucide="check-circle-2" class="w-4 h-4 text-green-600 flex-shrink-0"></i>
            <p class="text-sm text-green-800"><%= flash[:notice] %></p>
          </div>
        <% end %>
        <% if flash[:alert] %>
          <div class="mx-6 mt-4 flex items-center gap-2 rounded-md border border-red-200 bg-red-50 px-4 py-3">
            <i data-lucide="alert-circle" class="w-4 h-4 text-red-600 flex-shrink-0"></i>
            <p class="text-sm text-red-800"><%= flash[:alert] %></p>
          </div>
        <% end %>

        <%= yield %>
      </main>
    </div>
  <% else %>
    <div class="min-h-full flex items-center justify-center py-12 px-4 bg-muted">
      <%= yield %>
    </div>
  <% end %>

  <script>lucide.createIcons();</script>
</body>
</html>
